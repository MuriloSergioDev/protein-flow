generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Protein {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime  @default(now())

  launches Launch[]
}

model Flowchart {
  id        String   @id @default(cuid())
  userId    String
  name      String
  nodes     Json
  edges     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Launch {
  id            String    @id @default(cuid())
  proteinId     String
  flowchartId   String
  flowchartName String
  year          Int
  month         Int
  status        String    @default("in_progress")
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  protein Protein      @relation(fields: [proteinId], references: [id])
  steps   LaunchStep[]

  @@unique([proteinId, flowchartId, year, month])
}

model LaunchStep {
  id          String    @id @default(cuid())
  launchId    String
  nodeId      String
  type        String
  content     String?
  photoUrl    String?
  quantity    Float?
  completedAt DateTime?

  launch Launch @relation(fields: [launchId], references: [id], onDelete: Cascade)
}
